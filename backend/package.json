{
  "name": "f1-gp-reservation",
  "version": "1.0.0",
  "description": "F1 GP grandstand reservation API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --runInBand",
    "lint": "eslint src --ext .ts",
    "lintfix": "eslint src --ext .ts --fix && prettier --write src"
  },
  "dependencies": {
    "better-sqlite3": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/express": "^4",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/supertest": "^6",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "eslint-config-prettier": "^9",
    "jest": "^29",
    "prettier": "^3",
    "supertest": "^6",
    "ts-jest": "^29",
    "ts-node-dev": "^2",
    "typescript": "^5"
  }
}
